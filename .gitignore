# Secrets / env material never enter git (ai-dev-ground.md §4)
**/*.env
!**/*.env.example
!**/env.example
# Exception: OpenShell gateway config — driver + bind only, NO secrets.
# Symlinked to ~/.config/openshell/gateway.env by bootstrap/setup-host.sh.
!openshell/gateway.env
*.key
*-key.pem          # mkcert private keys
traefik/certs/ca/rootCA-key.pem
*.age
# Secrets directory — Bedrock keys, future agent API keys. Never commit.
.secrets/

# editor swap files
*.swp
