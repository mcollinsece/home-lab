# Optional — only if you're building your own image (skip it when using an
# upstream image directly in app.container / compose.yaml).
#
# Build & push to the local registry so the image is versioned and k8s-ready:
#   podman build -t localhost:5000/<name>:0.1.0 projects/<name>
#   podman push   localhost:5000/<name>:0.1.0
FROM docker.io/library/python:3.12-slim

WORKDIR /app

# Dependencies first for layer caching.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Document the port the app listens on; Traefik routes to it (set
# loadbalancer.server.port to match if it isn't 80).
EXPOSE 8080

CMD ["python", "main.py"]
