# OpenClaw + OpenShell CLI — custom image for the director container.
#
# The upstream openclaw/openclaw image handles the agent harness; this layer
# adds the openshell CLI so OpenClaw can create/manage worker sandboxes through
# the gateway running on the host (host.containers.internal:17670).
#
# Build and push to local registry:
#   podman build -t registry.lab.lan/openclaw:latest openclaw/
#   podman push --tls-verify=false registry.lab.lan/openclaw:latest
#
# Then update openclaw.container Image= to registry.lab.lan/openclaw:latest.
FROM docker.io/openclaw/openclaw:latest

# Install openshell CLI (same version as the host — see setup-host.sh).
ARG OPENSHELL_VERSION=v0.0.62
RUN curl -LsSf https://raw.githubusercontent.com/NVIDIA/OpenShell/main/install.sh | \
    OPENSHELL_VERSION=${OPENSHELL_VERSION} sh

# Point openshell at the host gateway.
# host.containers.internal resolves to the Podman host from inside a container.
ENV OPENSHELL_GATEWAY_HOST=host.containers.internal
ENV OPENSHELL_GATEWAY_PORT=17670
