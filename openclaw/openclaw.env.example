# openclaw.env — runtime configuration for the OpenClaw director container.
# Copy to openclaw.env (gitignored), fill in values, then start the service.
# Secrets (ANTHROPIC_API_KEY) are injected via Podman secrets in the Quadlet,
# not here — this file is for non-secret configuration only.

# Gateway auth — required when binding to 0.0.0.0 in container mode.
# Use password (simpler, typed in the UI login screen):
OPENCLAW_GATEWAY_PASSWORD=<choose a password>
# Or use a token (for API/scripted access): generate with openssl rand -hex 32
# OPENCLAW_GATEWAY_TOKEN=<generate with: openssl rand -hex 32>

# OpenShell gateway — where OpenClaw should look for the sandbox backend.
# host.containers.internal resolves to the Podman host from inside the container.
OPENSHELL_GATEWAY_URL=http://host.containers.internal:17670

# Default model for OpenClaw.
#
# Primary: claude-cli backend — reuses the host `claude login` session via the
#   mounted ~/.claude volume. No API key needed. Anthropic has sanctioned this usage.
#   Draws from monthly Agent SDK credit (from June 15 2026), then API rates.
OPENCLAW_DEFAULT_MODEL=claude-cli/claude-sonnet-4-6
#
# Fallback: AWS Bedrock — auto-detected from bedrock_aws_* Podman secrets.
#   Uncomment to make Bedrock the primary instead:
# OPENCLAW_DEFAULT_MODEL=amazon-bedrock/us.anthropic.claude-sonnet-4-6
#
# Verify available models after startup: openclaw models list

# Optional: default policy applied when OpenClaw creates worker sandboxes.
# Must be a policy ID already registered with the gateway, or a path
# accessible inside the container (e.g. mount openshell/policies/ as a volume).
# OPENCLAW_DEFAULT_SANDBOX_POLICY=claude-code
